{
  "name": "nodeplayer-addon",
  "version": "0.2.3",
  "description": "An Electron native player addon, support RTSP and RTMP",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./video-player": {
      "import": "./dist/video-player.mjs",
      "require": "./dist/video-player.umd.js",
      "default": "./dist/video-player.mjs"
    }
  },
  "files": [
    "dist",
    "prebuilds"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illuspas/nodeplayer-addon.git"
  },
  "keywords": [
    "electron",
    "addon",
    "native",
    "player",
    "rtsp",
    "rtmp"
  ],
  "author": "Chen Mingliang",
  "license": "",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/illuspas/nodeplayer-addon/issues"
  },
  "homepage": "https://github.com/illuspas/nodeplayer-addon#readme"
}
